# Copy to backend/.env and fill as you wire real adapters.
PORT=8787

# Wispr Flow dictation (https://wisprflow.ai/developers) — org API key (fl-...)
WISPR_FLOW_API_KEY=
WISPR_WS_URL=wss://platform-api.wisprflow.ai/api/v1/dash/ws

# AI + voice  (all optional — app runs keyless; these upgrade quality)
# LLM for summaries + onboarding + producer. Set ONE of the following providers.
#
# Groq — FREE + fast, runs strong open models (Llama 3.3 70B). Easiest free route.
# Get one: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile        # optional override
#
# OR Claude — highest quality, paid. https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8           # optional; default claude-haiku-4-5 (cheap/fast)
# (If both are set, Groq is used.)

# Semantic news relevance + dedup (workflow #5). Set ONE (Gemini is free).
# Gemini — FREE tier, rate-limited (not metered), no card. Get a key:
# https://aistudio.google.com → Get API key → Create API key
GEMINI_API_KEY=
# OR OpenAI embeddings (~pennies/month) — reuses OPENAI_API_KEY below.

# Premium host voice (natural narrator instead of the free robotic Google voice).
# ElevenLabs (best): https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=                        # pick from your ElevenLabs Voice Library (default: Rachel)
# OR OpenAI TTS (also powers embeddings): https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_TTS_VOICE=alloy

# Content sources
NEWS_API_KEY=
GUARDIAN_API_KEY=
LISTEN_NOTES_API_KEY=
PODCAST_INDEX_KEY=
PODCAST_INDEX_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Accounts + cloud profiles (optional; full guide in docs/AUTH.md)
# Supabase = Postgres + Google login + per-user profiles synced across devices.
# Project Settings -> API. service_role key is SERVER-ONLY (never ship to the client).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Google OAuth client id for "Sign in with Google" (also set in Supabase -> Auth -> Google)
GOOGLE_CLIENT_ID=

# Infra (later)
DATABASE_URL=
REDIS_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
